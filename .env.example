# App origin (production)
BETTER_AUTH_URL=https://www.nullxesdai.online
NEXT_PUBLIC_BETTER_AUTH_URL=https://www.nullxesdai.online

# Neon PostgreSQL — required at runtime (Vercel + local). Migrations run on `npm run build`.
DATABASE_URL=

# Email (Resend) — https://resend.com/docs/send-with-nextjs
RESEND_API_KEY=
# Transactional auth mail: OTP, password reset, invites
RESEND_FROM_EMAIL="Yuki Nakora NULLXES <noreply@nullxesdai.online>"
# Future Resend Automations / outbound (not used for auth OTP)
# RESEND_AUTOMATION_FROM_EMAIL="Yuki Nakora <yukinakora@nullxesdai.online>"
# Mission contact digest recipient (verified leads summary)
# MISSION_CONTACTS_DIGEST_EMAIL=ceo@nullxes.com

# Post-login email OTP step-up (custom flow; server-only flag)
EMAIL_OTP_STEP_UP_ENABLED=false

# Require verified email for sign-in and registration (opt-in; needs Resend)
REQUIRE_EMAIL_VERIFICATION=false

# GitHub OAuth — https://better-auth.com/docs/authentication/github
# Callback (prod): https://www.nullxesdai.online/api/auth/callback/github
# Callback (local): http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional: protect GET /api/health/db from public probing (Vercel/monitoring sends x-health-token)
# HEALTH_CHECK_TOKEN=

# OpenAI web search (Responses API web_search tool) — optional model override
# OPENAI_WEB_SEARCH_MODEL=gpt-4.1-mini

# Polar billing — https://polar.sh/docs/api-reference/introduction
# Products are resolved at runtime via metadata.plan / metadata.tier (no product ID env vars).
# Run once after creating a new Polar org: npm run polar:setup
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
# sandbox | production (default production)
POLAR_SERVER=production
# POLAR_SUCCESS_URL=
# POLAR_RETURN_URL=
# Personas are distributed across keys; cap per key (default 1) is configurable:
# ANAM_MAX_PERSONAS_PER_KEY=1
# Default lab for new custom avatars (e.g. ANAM_API_KEY_9 when that key is empty):
# ANAM_DEFAULT_AVATAR_SLOT=ANAM_API_KEY_9
# One-shot avatars per Anam account (default 1 on free tier):
# ANAM_ONE_SHOT_CAP_PER_KEY=1
# Anam Talk voice detection (0–1; higher = responds earlier). Default 0.5
# ANAM_END_OF_SPEECH_SENSITIVITY=0.6
# NEXT_PUBLIC_ANAM_END_OF_SPEECH_SENSITIVITY=0.6
# Seconds of user silence before turn is considered complete (0.5–10, default 3)
# ANAM_SILENCE_BEFORE_AUTO_END_TURN_SECONDS=3
# ANAM_SILENCE_BEFORE_SKIP_TURN_SECONDS=15
# ANAM_SILENCE_BEFORE_SESSION_END_SECONDS=60
# ANAM_SPEECH_ENHANCEMENT_LEVEL=0.8
# Cara 4 landscape: set width + height together (omit both for avatar default)
# ANAM_TALK_VIDEO_WIDTH=1152
# ANAM_TALK_VIDEO_HEIGHT=768
# ANAM_TALK_VIDEO_QUALITY=auto
# Comma-separated platform admin emails (Anam key pool dashboard). Default: ceo@nullxes.com
# PLATFORM_ADMIN_EMAILS=ceo@nullxes.com
ANAM_API_KEY=
ANAM_API_KEY_2=
ANAM_API_KEY_3=
ANAM_API_KEY_4=
ANAM_API_KEY_5=
ANAM_API_KEY_6=
ANAM_API_KEY_7=
ANAM_API_KEY_8=
ANAM_API_KEY_9=
ANAM_API_KEY_10=
ANAM_API_KEY_11=
# xAI Grok Voice Agent — https://docs.x.ai/developers/model-capabilities/audio/voice
XAI_API_KEY=
# Adeline Kalen pilot (console agent id)
XAI_VOICE_AGENT_ADELINE=agent_yLXnJLDucVtucCck
