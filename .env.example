# App origin (production)
BETTER_AUTH_URL=https://www.nullxesdai.online
NEXT_PUBLIC_BETTER_AUTH_URL=https://www.nullxesdai.online

# Better Auth secret — required in production (throws if missing)
BETTER_AUTH_SECRET=

# Neon PostgreSQL — required at runtime (Vercel + local). Migrations run on `npm run build`.
DATABASE_URL=

# Field encryption (AES-256-GCM) — required in production
DATA_ENCRYPTION_KEY=

# Email (Resend) — https://resend.com/docs/send-with-nextjs
RESEND_API_KEY=
# Transactional auth mail: OTP, password reset, invites
RESEND_FROM_EMAIL="Yuki Nakora NULLXES <noreply@nullxesdai.online>"
# Future Resend Automations / outbound (not used for auth OTP)
# RESEND_AUTOMATION_FROM_EMAIL="Yuki Nakora <yukinakora@nullxesdai.online>"
# Mission contact digest recipient (verified leads summary)
# MISSION_CONTACTS_DIGEST_EMAIL=ceo@nullxes.com

# Post-login email OTP step-up (custom flow; server-only flag)
# Local: false. Production: REQUIRED true (assertProductionSecretsConfigured).
EMAIL_OTP_STEP_UP_ENABLED=false
NEXT_PUBLIC_EMAIL_OTP_STEP_UP_ENABLED=false

# Require verified email for sign-in and registration
# Local: false. Production: REQUIRED true.
REQUIRE_EMAIL_VERIFICATION=false

# Skip admin 2FA / OTP gates — MUST be unset in production (boot assert).
# TWO_FACTOR_GATE_BYPASS_EMAILS=
# EMAIL_OTP_BYPASS_EMAILS=

# Seed acquiring auditor (npm run auth:seed-acquiring) — never commit the password
# ACQUIRING_AUDITOR_EMAIL=acquiring@nullxes.com
# ACQUIRING_AUDITOR_PASSWORD=
# GitHub OAuth — https://better-auth.com/docs/authentication/github
# Callback (prod): https://www.nullxesdai.online/api/auth/callback/github
# Callback (local): http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth — https://better-auth.com/docs/authentication/google
# Callback (prod): https://www.nullxesdai.online/api/auth/callback/google
# Callback (local): http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Protect GET /api/health/db (required in production — endpoint fails closed without it)
HEALTH_CHECK_TOKEN=

# API key hashing pepper (recommended in production)
API_KEY_PEPPER=

# Sentry — leave empty to disable
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Inngest — signing key required in production
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
# Never set INNGEST_DEV=1 in production

# Stream Chat / Video
STREAM_API_KEY=
STREAM_SECRET_KEY=
NEXT_PUBLIC_STREAM_API_KEY=

# Optional Talk overrides
# TALK_DEMO_SESSION_CAP_SECONDS=0
# TALK_SLA_MODE=observe
# TALK_PERF_LOG=0

# OpenAI web search (Responses API web_search tool) — optional model override
# OPENAI_WEB_SEARCH_MODEL=gpt-4.1-mini

# Polar billing — https://polar.sh/docs/api-reference/introduction
# Products are resolved at runtime via metadata.plan / metadata.tier (no product ID env vars).
# Run once after creating a new Polar org: npm run polar:setup
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
# sandbox | production (default production)
POLAR_SERVER=production
# POLAR_SUCCESS_URL=
# POLAR_RETURN_URL=

# Slack workspace OAuth (Settings → Integrations)
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=

# Microsoft Teams OAuth (Settings → Integrations)
# MICROSOFT_TEAMS_CLIENT_ID=
# MICROSOFT_TEAMS_CLIENT_SECRET=
# MICROSOFT_TEAMS_TENANT_ID=common

# Personas are distributed across keys; cap per key (default 1) is configurable:
# ANAM_MAX_PERSONAS_PER_KEY=1
# Default lab for new custom avatars (e.g. ANAM_API_KEY_9 when that key is empty):
# ANAM_DEFAULT_AVATAR_SLOT=ANAM_API_KEY_9
# One-shot avatars per Anam account (default 1 on free tier):
# ANAM_ONE_SHOT_CAP_PER_KEY=1
# Anam Talk voice detection (0–1; higher = responds earlier). Default 0.5
# ANAM_END_OF_SPEECH_SENSITIVITY=0.6
# NEXT_PUBLIC_ANAM_END_OF_SPEECH_SENSITIVITY=0.6
# Seconds of user silence before turn is considered complete (0.5–10, default 3)
# ANAM_SILENCE_BEFORE_AUTO_END_TURN_SECONDS=3
# ANAM_SILENCE_BEFORE_SKIP_TURN_SECONDS=15
# ANAM_SILENCE_BEFORE_SESSION_END_SECONDS=60
# ANAM_SPEECH_ENHANCEMENT_LEVEL=0.8
# Talk video size. Default is always 720×480 (cara-3 / sara-3).
# Do NOT set 1152×768 unless avatars are cara-4 AND you opt in:
# ANAM_TALK_ALLOW_CUSTOM_VIDEO_DIMS=1
# ANAM_TALK_VIDEO_WIDTH=720
# ANAM_TALK_VIDEO_HEIGHT=480
# ANAM_TALK_VIDEO_QUALITY=auto
# Soft in-memory Anam proxy buckets (off by default).
# ANAM_PROXY_QUOTA_ENABLED=1
# Comma-separated platform admin emails (Anam key pool dashboard). Default: ceo@nullxes.com
# Platform operators (Anam Key pool UI, session kill switch). Always includes ceo@nullxes.com.
# PLATFORM_ADMIN_EMAILS=ops@nullxes.com,qa@nullxes.com
ANAM_API_KEY=
ANAM_API_KEY_2=
ANAM_API_KEY_3=
ANAM_API_KEY_4=
ANAM_API_KEY_5=
ANAM_API_KEY_6=
ANAM_API_KEY_7=
ANAM_API_KEY_8=
ANAM_API_KEY_9=
ANAM_API_KEY_10=
ANAM_API_KEY_11=
# xAI Grok Voice Agent — https://docs.x.ai/developers/model-capabilities/audio/voice
XAI_API_KEY=
# Adeline Kalen pilot (console agent id)
XAI_VOICE_AGENT_ADELINE=agent_yLXnJLDucVtucCck
# Anna Maria landing / Grok Voice (console agent id)
XAI_VOICE_AGENT_ANNA=agent_8z4syR6vTpYwTuj

# Brain providers — platform defaults (org keys override in Settings → AI)
OPENAI_API_KEY=
# OPENAI_API_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
# GEMINI_API_KEY=

# NULLXES platform brain API (preferred when SDK is live)
# NULLXES_API_BASE_URL=https://api.nullxes.com/v1
# NULLXES_API_KEY=
# NULLXES_API_DEFAULT_MODEL=nullxes-brain-v1

# Legacy NULLXES vLLM endpoint (OpenAI-compatible fallback)
# NULLXES_BRAIN_API_BASE_URL=
# NULLXES_BRAIN_API_KEY=
# NULLXES_BRAIN_MODEL=MagistrTheOne/SHUTEN-DOJI
# NULLXES_BRAIN_SUPPORTS_TOOLS=true

# T-Bank Acquiring (production by default; set TBANK_ENV=test for sandbox)
# TBANK_TERMINAL_KEY=
# TBANK_PASSWORD=
# TBANK_ENV=production
# TBANK_API_BASE=https://securepay.tinkoff.ru
# TBANK_TAXATION=usn_income
# TBANK_VAT=none
# TBANK_RECEIPT=1

# T-Bank TLS — Russian Trusted CA (Minцифры). Public CA bundle in /certs.
# Local: NODE_EXTRA_CA_CERTS=./certs/russian-trusted-ca-bundle.pem
# Vercel: NODE_EXTRA_CA_CERTS=/var/task/certs/russian-trusted-ca-bundle.pem
# NODE_EXTRA_CA_CERTS=

# Closed Founding Partners program (invite / whitelist). Comma-separated org UUIDs.
# FOUNDING_PARTNER_ORG_IDS=
